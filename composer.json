{
    "name": "shebaoting/flarum-avatar",
    "description": "Reddit-style avatar editor for Flarum.",
    "keywords": [
        "flarum",
        "avatar",
        "decoration"
    ],
    "type": "flarum-extension",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "flarum/core": "^2.0.0-beta"
    },
    "authors": [
        {
            "name": "Shebaoting",
            "email": "th9th@th9th.com",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "Shebaoting\\FlarumAvatar\\": "src/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "Flarum Avatar",
            "category": "feature",
            "icon": {
                "name": "fas fa-user-astronaut",
                "color": "#fff",
                "backgroundColor": "#ff4500"
            }
        },
        "flarum-cli": {
            "modules": {
                "admin": true,
                "forum": true,
                "js": true,
                "css": true,
                "locale": true,
                "typescript": true
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
